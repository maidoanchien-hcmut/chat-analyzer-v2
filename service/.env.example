# Service runtime env for local development.
# Provider config stays service-owned and must not be copied into page onboarding or page-local prompt config.

# Default safe mode for local/dev/test.
ANALYSIS_SERVICE_RUNTIME_MODE=deterministic_dev

# Required only when ANALYSIS_SERVICE_RUNTIME_MODE=openai_compatible_live.
ANALYSIS_SERVICE_PROVIDER_NAME=
ANALYSIS_SERVICE_PROVIDER_BASE_URL=
ANALYSIS_SERVICE_PROVIDER_API_KEY=
ANALYSIS_SERVICE_PROVIDER_MODEL=

ANALYSIS_SERVICE_GRPC_HOST=0.0.0.0
ANALYSIS_SERVICE_GRPC_PORT=50051
ANALYSIS_SERVICE_GRPC_MAX_MESSAGE_LENGTH=67108864
ANALYSIS_SERVICE_GRPC_MAX_WORKERS=8
ANALYSIS_SERVICE_REQUEST_TIMEOUT_SECONDS=60
ANALYSIS_SERVICE_GENERATION_TEMPERATURE=0
ANALYSIS_SERVICE_GENERATION_TOP_P=1
ANALYSIS_SERVICE_GENERATION_MAX_OUTPUT_TOKENS=1200
ANALYSIS_SERVICE_LOG_LEVEL=INFO
