NODE_ENV="development"
HOST="0.0.0.0"
PORT="3000"

DB_PROTOCOL="postgresql"
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="chat_analyzer_v2"
DB_USER="chat_admin"
DB_PASSWORD="change_this_password"
DB_SCHEMA="public"
DATABASE_URL="postgresql://chat_admin:change_this_password@localhost:5432/chat_analyzer_v2?schema=public"

REDIS_PROTOCOL="redis"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_DB="0"
REDIS_URL="${REDIS_PROTOCOL}://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}"

CORS_ORIGIN="http://localhost:5173"

JWT_ACCESS_SECRET="replace_me"
JWT_REFRESH_SECRET="replace_me_too"
JWT_ACCESS_TOKEN_TTL="900"
JWT_REFRESH_TOKEN_TTL="2592000"

AUTH_REFRESH_COOKIE_NAME="chat_analyzer_refresh_token"
AUTH_REFRESH_COOKIE_SECURE="false"
AUTH_REFRESH_COOKIE_SAME_SITE="strict"
AUTH_REFRESH_COOKIE_PATH="/auth"
AUTH_REFRESH_COOKIE_DOMAIN=""
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS="5"
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS="900"
