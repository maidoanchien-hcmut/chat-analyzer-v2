generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Platform {
  id                 Int                     @id @default(autoincrement())
  code               String                  @unique
  name               String
  brandName          String?                 @map("brand_name")
  isDefault          Boolean                 @default(false) @map("is_default")
  isActive           Boolean                 @default(true) @map("is_active")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")
  authUsers          AuthUser[]
  refreshTokens      AuthRefreshToken[]
  roles              AuthRole[]
  permissions        AuthPermission[]
  usersOnRoles       AuthUsersOnRoles[]
  rolesOnPermissions AuthRolesOnPermissions[]
  auditLogs          AuthAuditLog[]

  @@map("platform")
}

model AuthUser {
  id                 Int                @id @default(autoincrement())
  platformId         Int                @map("platform_id")
  identifier         String
  email              String?
  displayName        String             @map("display_name")
  passwordHash       String             @map("password_hash")
  passwordChangedAt  DateTime           @map("password_changed_at")
  mustChangePassword Boolean            @default(false) @map("must_change_password")
  authzVersion       Int                @default(1) @map("authz_version")
  isActive           Boolean            @default(true) @map("is_active")
  disabledAt         DateTime?          @map("disabled_at")
  lastLoginAt        DateTime?          @map("last_login_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  platform           Platform           @relation(fields: [platformId], references: [id], onDelete: Restrict)
  refreshTokens      AuthRefreshToken[]
  roles              AuthUsersOnRoles[]
  auditLogs          AuthAuditLog[]

  @@unique([platformId, identifier])
  @@unique([platformId, email])
  @@index([platformId, isActive])
  @@map("auth_user")
}

model AuthRefreshToken {
  id                 Int                @id @default(autoincrement())
  platformId         Int                @map("platform_id")
  userId             Int                @map("user_id")
  tokenHash          String             @unique @map("token_hash")
  familyId           String             @map("family_id")
  isActive           Boolean            @default(true) @map("is_active")
  deviceLabel        String?            @map("device_label")
  ipAddress          String?            @map("ip_address")
  userAgent          String?            @map("user_agent")
  lastSeenAt         DateTime?          @map("last_seen_at")
  expiresAt          DateTime           @map("expires_at")
  revokedAt          DateTime?          @map("revoked_at")
  revokedReason      String?            @map("revoked_reason")
  rotatedFromTokenId Int?               @map("rotated_from_token_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  platform           Platform           @relation(fields: [platformId], references: [id], onDelete: Restrict)
  user               AuthUser           @relation(fields: [userId], references: [id], onDelete: Restrict)
  rotatedFrom        AuthRefreshToken?  @relation("AuthRefreshRotation", fields: [rotatedFromTokenId], references: [id], onDelete: SetNull)
  rotatedInto        AuthRefreshToken[] @relation("AuthRefreshRotation")

  @@index([userId, isActive])
  @@index([platformId, familyId])
  @@index([expiresAt])
  @@map("auth_refresh_token")
}

model AuthRole {
  id          Int                      @id @default(autoincrement())
  platformId  Int                      @map("platform_id")
  code        String
  name        String
  description String?
  isActive    Boolean                  @default(true) @map("is_active")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  platform    Platform                 @relation(fields: [platformId], references: [id], onDelete: Restrict)
  users       AuthUsersOnRoles[]
  permissions AuthRolesOnPermissions[]

  @@unique([platformId, code])
  @@map("auth_role")
}

model AuthPermission {
  id          Int                      @id @default(autoincrement())
  platformId  Int                      @map("platform_id")
  code        String
  name        String
  description String?
  screen      String?
  isActive    Boolean                  @default(true) @map("is_active")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  platform    Platform                 @relation(fields: [platformId], references: [id], onDelete: Restrict)
  roles       AuthRolesOnPermissions[]

  @@unique([platformId, code])
  @@map("auth_permission")
}

model AuthUsersOnRoles {
  id         Int       @id @default(autoincrement())
  platformId Int       @map("platform_id")
  userId     Int       @map("user_id")
  roleId     Int       @map("role_id")
  isActive   Boolean   @default(true) @map("is_active")
  assignedAt DateTime  @default(now()) @map("assigned_at")
  revokedAt  DateTime? @map("revoked_at")
  platform   Platform  @relation(fields: [platformId], references: [id], onDelete: Restrict)
  user       AuthUser  @relation(fields: [userId], references: [id], onDelete: Restrict)
  role       AuthRole  @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([platformId, userId, roleId])
  @@index([platformId, userId, isActive])
  @@map("auth_users_on_roles")
}

model AuthRolesOnPermissions {
  id           Int            @id @default(autoincrement())
  platformId   Int            @map("platform_id")
  roleId       Int            @map("role_id")
  permissionId Int            @map("permission_id")
  isActive     Boolean        @default(true) @map("is_active")
  assignedAt   DateTime       @default(now()) @map("assigned_at")
  revokedAt    DateTime?      @map("revoked_at")
  platform     Platform       @relation(fields: [platformId], references: [id], onDelete: Restrict)
  role         AuthRole       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission   AuthPermission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([platformId, roleId, permissionId])
  @@index([platformId, roleId, isActive])
  @@map("auth_roles_on_permissions")
}

model AuthAuditLog {
  id         Int       @id @default(autoincrement())
  platformId Int       @map("platform_id")
  userId     Int?      @map("user_id")
  action     String
  targetType String?   @map("target_type")
  targetId   String?   @map("target_id")
  success    Boolean   @default(true)
  metadata   Json?
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  createdAt  DateTime  @default(now()) @map("created_at")
  platform   Platform  @relation(fields: [platformId], references: [id], onDelete: Restrict)
  user       AuthUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([platformId, createdAt])
  @@index([userId, createdAt])
  @@map("auth_audit_log")
}

model EtlRun {
  id                            String            @id @default(uuid()) @db.Uuid
  runGroupId                    String?           @map("run_group_id") @db.Uuid
  runMode                       String            @map("run_mode")
  pageId                        String            @map("page_id")
  targetDate                    DateTime          @map("target_date") @db.Date
  businessTimezone              String            @map("business_timezone")
  requestedWindowStartAt        DateTime?         @map("requested_window_start_at") @db.Timestamptz(6)
  requestedWindowEndExclusiveAt DateTime?         @map("requested_window_end_exclusive_at") @db.Timestamptz(6)
  windowStartAt                 DateTime          @map("window_start_at") @db.Timestamptz(6)
  windowEndExclusiveAt          DateTime          @map("window_end_exclusive_at") @db.Timestamptz(6)
  status                        String
  snapshotVersion               Int               @map("snapshot_version")
  isPublished                   Boolean           @default(false) @map("is_published")
  tagDictionaryJson             Json              @map("tag_dictionary_json")
  metricsJson                   Json              @map("metrics_json")
  errorText                     String?           @map("error_text")
  startedAt                     DateTime          @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt                    DateTime?         @map("finished_at") @db.Timestamptz(6)
  conversationDays              ConversationDay[]
  messages                      Message[]

  @@unique([pageId, targetDate, snapshotVersion])
  @@index([runGroupId])
  @@index([pageId])
  @@index([targetDate])
  @@index([status])
  @@index([isPublished])
  @@index([startedAt])
  @@index([finishedAt])
  @@map("etl_run")
}

model ConversationDay {
  id                             String    @id @default(uuid()) @db.Uuid
  etlRunId                       String    @map("etl_run_id") @db.Uuid
  conversationId                 String    @map("conversation_id")
  customerDisplayName            String?   @map("customer_display_name")
  conversationInsertedAt         DateTime? @map("conversation_inserted_at") @db.Timestamptz(6)
  conversationUpdatedAt          DateTime? @map("conversation_updated_at") @db.Timestamptz(6)
  messageCountSeenFromSource     Int       @map("message_count_seen_from_source")
  normalizedPhoneCandidatesJson  Json      @map("normalized_phone_candidates_json")
  currentTagsJson                Json      @map("current_tags_json")
  observedTagEventsJson          Json      @map("observed_tag_events_json")
  normalizedTagSignalsJson       Json      @map("normalized_tag_signals_json")
  openingBlocksJson              Json      @map("opening_blocks_json")
  firstMeaningfulHumanMessageId  String?   @map("first_meaningful_human_message_id")
  firstMeaningfulHumanSenderRole String?   @map("first_meaningful_human_sender_role")
  sourceConversationJson         Json      @map("source_conversation_json")
  createdAt                      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  etlRun                         EtlRun    @relation(fields: [etlRunId], references: [id], onDelete: Cascade)
  messages                       Message[]

  @@unique([etlRunId, conversationId])
  @@index([etlRunId])
  @@index([conversationId])
  @@index([customerDisplayName])
  @@index([createdAt])
  @@map("conversation_day")
}

model Message {
  id                       String          @id @default(uuid()) @db.Uuid
  conversationDayId        String          @map("conversation_day_id") @db.Uuid
  etlRunId                 String          @map("etl_run_id") @db.Uuid
  messageId                String          @map("message_id")
  conversationId           String          @map("conversation_id")
  insertedAt               DateTime        @map("inserted_at") @db.Timestamptz(6)
  senderSourceId           String?         @map("sender_source_id")
  senderName               String?         @map("sender_name")
  senderRole               String          @map("sender_role")
  sourceMessageTypeRaw     String?         @map("source_message_type_raw")
  messageType              String          @map("message_type")
  redactedText             String?         @map("redacted_text")
  attachmentsJson          Json            @map("attachments_json")
  messageTagsJson          Json            @map("message_tags_json")
  isMeaningfulHumanMessage Boolean         @map("is_meaningful_human_message")
  sourceMessageJsonRedacted Json           @map("source_message_json_redacted")
  createdAt                DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  conversationDay          ConversationDay @relation(fields: [conversationDayId], references: [id], onDelete: Cascade)
  etlRun                   EtlRun          @relation(fields: [etlRunId], references: [id], onDelete: Cascade)

  @@unique([etlRunId, messageId])
  @@index([conversationDayId, insertedAt])
  @@index([conversationId, insertedAt])
  @@index([isMeaningfulHumanMessage])
  @@map("message")
}

model ThreadCustomerMapping {
  pageId          String   @map("page_id")
  threadId        String   @map("thread_id")
  customerId      String   @map("customer_id")
  mappedPhoneE164 String?  @map("mapped_phone_e164")
  mappingMethod   String   @map("mapping_method")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([pageId, threadId])
  @@index([customerId])
  @@index([mappingMethod])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("thread_customer_mapping")
}
